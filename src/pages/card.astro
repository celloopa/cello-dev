---
import cv from "@cv";
import QRCode from "qrcode";
import "@fontsource/geist-mono/400.css";
import "@fontsource/geist-mono/700.css";
import "@fontsource/geist-mono/900.css";
import "@/styles/colors.css";
import Mail from "@/icons/Mail.astro";
import Phone from "@/icons/Phone.astro";
import LinkedIn from "@/icons/LinkedIn.astro";
import GitHub from "@/icons/GitHub.astro";

const { basics } = cv;
const { name, label, summary, email, phone, url, location, profiles } = basics;

const cardUrl = new URL("/card", url).toString();
const vCardUrl = new URL("/contact.vcf", url).toString();
const siteHost = new URL(url).hostname.replace(/^www\./, "");
const phoneDigits = phone.replace(/\D/g, "");
const phoneHref = `tel:${phoneDigits.length === 10 ? `+1${phoneDigits}` : `+${phoneDigits}`}`;
const locationLabel = [location.city, location.region]
  .filter(Boolean)
  .join(", ");
const linkedin = profiles.find(({ network }) => network === "LinkedIn")?.url;
const github = profiles.find(({ network }) => network === "GitHub")?.url;

const qrCodeSvg = await QRCode.toString(url, {
  type: "svg",
  errorCorrectionLevel: "H",
  margin: 1,
  color: {
    dark: "#001A11",
    light: "#FFF8ED",
  },
});
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta
      name="description"
      content="Conference card for Marcelo Rondon. Scan the QR code for the portfolio, save the contact card, or share via AirDrop."
    />
    <meta name="theme-color" content="#001A11" />
    <meta name="color-scheme" content="dark light" />
    <link rel="canonical" href={cardUrl} />
    <meta property="og:url" content={cardUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${name} | Conference Card`} />
    <meta
      property="og:description"
      content="Conference-ready contact page with QR, contact save, and quick share actions."
    />
    <meta property="og:image" content={`${url}/images/thumbnail.png`} />
    <title>{name} | Conference Card</title>
    <script is:inline>
      (() => {
        const savedTheme = localStorage.getItem("theme");
        const systemTheme = window.matchMedia("(prefers-color-scheme: dark)")
          .matches
          ? "dark"
          : "light";
        document.documentElement.setAttribute(
          "data-theme",
          savedTheme || systemTheme,
        );
      })();
    </script>
  </head>
  <body>
    <div class="page-shell">
      <main class="card-shell">
        <section class="identity-panel">
          <p class="eyebrow">Conference Card</p>
          <div class="intro">
            <div class="avatar-wrap">
              <img src="/images/profile.webp" alt={name} class="avatar" />
            </div>
            <div class="intro-copy">
              <h1>{name}</h1>
              <p class="role">{label}</p>
              <p class="meta">{locationLabel}</p>
            </div>
          </div>

          <p class="summary">{summary}</p>

          <div class="primary-actions" aria-label="Primary actions">
            <a
              class="action action-primary"
              href={url}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="action-title">Visit Portfolio</span>
              <span class="action-copy">{siteHost}</span>
            </a>
            <a class="action" href="/contact.vcf">
              <span class="action-title">Save Contact</span>
              <span class="action-copy">VCF for phone or desktop</span>
            </a>
            <button
              type="button"
              class="action action-share"
              data-share-button
              data-share-url={cardUrl}
              data-share-title={`${name} | Conference Card`}
              data-share-text={`Connect with ${name}.`}
            >
              <span class="action-title" data-share-label>Share Card</span>
              <span class="action-copy">AirDrop or copy link</span>
            </button>
          </div>

          <div class="secondary-links" aria-label="Contact links">
            <a class="detail-link" href={`mailto:${email}`}>
              <Mail />
              <span>{email}</span>
            </a>
            <a class="detail-link" href={phoneHref}>
              <Phone />
              <span>{phone}</span>
            </a>
            {
              linkedin && (
                <a
                  class="detail-link"
                  href={linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <LinkedIn />
                  <span>LinkedIn</span>
                </a>
              )
            }
            {
              github && (
                <a
                  class="detail-link"
                  href={github}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <GitHub />
                  <span>GitHub</span>
                </a>
              )
            }
          </div>

          <p class="share-note" data-share-status aria-live="polite">
            Open on iPhone to AirDrop, or copy the link anywhere else.
          </p>
        </section>

        <aside class="qr-panel">
          <p class="eyebrow">Scan To Visit</p>
          <a
            class="qr-frame"
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Open ${siteHost}`}
            set:html={qrCodeSvg}
          />
          <p class="qr-note">Scan for the portfolio, or use the actions alongside it.</p>
          <a class="mini-link" href={vCardUrl}>Direct contact file</a>
        </aside>
      </main>
    </div>

    <script is:inline>
      function initCardShare() {
        const shareButton = document.querySelector("[data-share-button]");
        const shareStatus = document.querySelector("[data-share-status]");
        const shareLabel = document.querySelector("[data-share-label]");

        if (
          !(shareButton instanceof HTMLButtonElement) ||
          !(shareStatus instanceof HTMLElement)
        ) {
          return;
        }

        if (shareButton.dataset.bound === "true") {
          return;
        }

        shareButton.dataset.bound = "true";

        const shareUrl = shareButton.dataset.shareUrl;
        const shareTitle = shareButton.dataset.shareTitle;
        const shareText = shareButton.dataset.shareText;

        if (!navigator.share && shareLabel instanceof HTMLElement) {
          shareLabel.textContent = "Copy Card Link";
        }

        shareButton.addEventListener("click", async () => {
          if (!shareUrl) {
            return;
          }

          try {
            if (navigator.share) {
              await navigator.share({
                title: shareTitle,
                text: shareText,
                url: shareUrl,
              });
              shareStatus.textContent = "Share sheet opened.";
              return;
            }

            if (navigator.clipboard?.writeText) {
              await navigator.clipboard.writeText(shareUrl);
              shareStatus.textContent = "Card link copied to the clipboard.";
              return;
            }

            shareStatus.textContent = shareUrl;
          } catch (error) {
            if (error instanceof DOMException && error.name === "AbortError") {
              return;
            }

            shareStatus.textContent = "Share failed on this browser.";
          }
        });
      }

      document.addEventListener("DOMContentLoaded", initCardShare);
      document.addEventListener("astro:after-swap", initCardShare);
    </script>
  </body>
</html>

<style is:global>
  html {
    font-family: "GeistMono", monospace;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-accent) 9%, var(--color-background)),
        var(--color-background) 18rem
      );
    color: var(--color-text);
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      linear-gradient(
        150deg,
        rgba(var(--color-accent-rgb), 0.05) 0,
        transparent 28%
      ),
      repeating-linear-gradient(
        60deg,
        rgba(var(--color-text-rgb), 0.03) 0,
        rgba(var(--color-text-rgb), 0.03) 2px,
        transparent 2px,
        transparent 28px
      ),
      repeating-linear-gradient(
        -60deg,
        rgba(var(--color-text-rgb), 0.02) 0,
        rgba(var(--color-text-rgb), 0.02) 2px,
        transparent 2px,
        transparent 28px
      ),
      var(--color-background);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  a,
  button {
    font: inherit;
  }
</style>

<style>
  .page-shell {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    padding: max(1.5rem, env(safe-area-inset-top)) 1.25rem
      max(1.5rem, env(safe-area-inset-bottom));
    display: grid;
    place-items: center;
  }

  .card-shell {
    width: min(100%, 1120px);
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(14rem, 24vw, 18rem);
    gap: 3rem;
    align-items: start;
  }

  .identity-panel,
  .qr-panel {
    position: relative;
  }

  .identity-panel {
    padding: 0;
    animation: slideLeft 0.8s cubic-bezier(0.16, 1, 0.3, 1) backwards;
    contain: layout paint;
  }

  .qr-panel {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
    max-width: 18rem;
    animation: slideRight 0.8s cubic-bezier(0.16, 1, 0.3, 1) backwards;
    contain: layout paint;
    content-visibility: auto;
    contain-intrinsic-size: 22rem;
  }

  .eyebrow {
    margin: 0 0 1rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .intro {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.25rem;
    align-items: center;
  }

  .avatar-wrap {
    width: clamp(5rem, 18vw, 7rem);
    aspect-ratio: 1;
    border: 3px solid var(--color-text);
    box-shadow: 10px 10px 0 var(--color-accent);
  }

  .avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(1.05) contrast(1.02);
  }

  @keyframes slideLeft {
    from {
      opacity: 0;
      transform: translateX(-48px);
    }

    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes slideRight {
    from {
      opacity: 0;
      transform: translateX(48px);
    }

    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  h1 {
    margin: 0;
    font-size: clamp(2.6rem, 9vw, 5.5rem);
    line-height: 0.92;
    letter-spacing: -0.08em;
    text-transform: uppercase;
  }

  .role,
  .meta,
  .summary,
  .share-note,
  .qr-note,
  .qr-link,
  .qr-label,
  .mini-link {
    margin: 0;
  }

  .role {
    margin-top: 0.65rem;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.5;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .meta {
    margin-top: 0.45rem;
    font-size: 0.95rem;
    color: rgba(var(--color-text-rgb), 0.72);
  }

  .summary {
    margin-top: 1.5rem;
    max-width: 44ch;
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(var(--color-text-rgb), 0.88);
  }

  .primary-actions {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .action {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    justify-content: center;
    min-height: 4.5rem;
    padding: 0.95rem 1rem;
    border: 2px solid var(--color-text);
    background: transparent;
    color: var(--color-text);
    text-align: left;
    text-decoration: none;
    cursor: pointer;
    transition:
      transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      background 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      color 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .action:hover,
  .action:focus-visible {
    transform: translateY(-2px);
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: var(--color-background);
  }

  .action-primary {
    border-color: var(--color-accent);
  }

  .action-title {
    display: block;
    font-size: 0.88rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .action-copy {
    display: block;
    font-size: 0.84rem;
    line-height: 1.4;
    color: rgba(var(--color-text-rgb), 0.72);
  }

  .action:hover .action-copy,
  .action:focus-visible .action-copy {
    color: inherit;
  }

  .secondary-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, max-content));
    gap: 0.75rem 1.25rem;
    margin-top: 1.5rem;
  }

  .detail-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 44px;
    color: rgba(var(--color-text-rgb), 0.8);
    font-size: 0.88rem;
    line-height: 1.4;
    text-decoration: none;
  }

  .detail-link :global(svg) {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .share-note {
    margin-top: 1.25rem;
    font-size: 0.88rem;
    line-height: 1.55;
    color: rgba(var(--color-text-rgb), 0.7);
  }

  .qr-frame {
    display: block;
    width: 100%;
    max-width: 16rem;
    aspect-ratio: 1;
    padding: 0.9rem;
    margin-top: 0.4rem;
    border: 2px solid var(--color-text);
    background: var(--color-paper);
  }

  .qr-frame :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }

  .qr-note {
    margin-top: 0.85rem;
    max-width: 22ch;
    font-size: 0.88rem;
    line-height: 1.55;
    color: rgba(var(--color-text-rgb), 0.72);
  }

  .mini-link {
    margin-top: 0.85rem;
    color: var(--color-accent);
    font-size: 0.84rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
  }

  @media (max-width: 960px) {
    .card-shell {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .qr-panel {
      order: 2;
      max-width: none;
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 1rem 1.5rem;
      align-items: start;
    }

    .qr-panel .eyebrow {
      grid-column: 1 / -1;
      margin-bottom: 0;
    }

    .qr-frame {
      grid-row: 2 / span 2;
      max-width: 14rem;
      margin-top: 0;
    }

    .qr-note {
      margin-top: 0;
      max-width: 28ch;
    }

    .mini-link {
      margin-top: 0.25rem;
      align-self: start;
    }

    h1 {
      font-size: clamp(2.8rem, 10vw, 4.8rem);
    }

    .primary-actions {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .action-share {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 700px) {
    .page-shell {
      padding-inline: 0.9rem;
    }

    .intro {
      grid-template-columns: 1fr;
    }

    h1 {
      font-size: clamp(2.6rem, 14vw, 4rem);
    }

    .secondary-links {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    .primary-actions {
      grid-template-columns: 1fr;
    }

    .qr-panel {
      display: flex;
      gap: 0;
    }

    .qr-panel .eyebrow {
      margin-bottom: 1rem;
    }

    .qr-frame {
      max-width: 15rem;
      margin-top: 0.4rem;
    }

    .qr-note,
    .mini-link {
      margin-top: 0.85rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .identity-panel,
    .qr-panel,
    .action {
      animation: none !important;
      transition: none !important;
    }
  }
</style>
