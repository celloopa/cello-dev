---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/sections/Hero.astro";
import Experience from "@/components/sections/Experience.astro";
import About from "@/components/sections/About.astro";
import Education from "@/components/sections/Education.astro";
import Skills from "@/components/sections/Skills.astro";
import Projects from "@/components/sections/Projects.astro";
import Section from "@/components/Section.astro";
import { basics } from "@cv";

const { name, email, profiles } = basics;
const github = profiles.find(({ network }) => network === "GitHub")?.url;
---

<Layout title="Cello's Resume">
  <div class="print-header print">
    {name} · {email}
    {github && `· ${github}`}
  </div>
  <Hero />
  <Section>
    <a href="/files/marcelo_rondon-resume.pdf" download class="download-btn">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
      </svg>
      <span>Download PDF</span>
    </a>
  </Section>
  <Section title="About">
    <About />
  </Section>
  <div class="section-divider" aria-hidden="true"></div>
  <Section title="Experience">
    <Experience />
  </Section>
  <div class="section-divider" aria-hidden="true"></div>
  <Section title="Skills">
    <Skills />
  </Section>
  <div class="section-divider" aria-hidden="true"></div>
  <Section title="Projects">
    <Projects />
  </Section>
  <div class="section-divider" aria-hidden="true"></div>
  <Section title="Education">
    <Education />
  </Section>
</Layout>

<style>
  .print-header {
    display: none;
  }

  .download-btn {
    display: inline-flex;
    position: relative;
    z-index: 0;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.5rem;
    background: transparent;
    color: var(--color-text);
    border: 3px solid var(--color-text);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .download-btn::before {
    content: "";
    position: absolute;
    top: 4px;
    left: 4px;
    right: -4px;
    bottom: -4px;
    z-index: -1;
    border: 3px solid var(--color-accent);
    pointer-events: none;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .download-btn:hover::before,
  .download-btn:focus-visible::before {
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
  }

  .download-btn:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-background);
  }

  .download-btn svg {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .download-btn:hover svg {
    transform: translateY(2px);
  }

  .section-divider {
    max-width: 1100px;
    margin: clamp(2rem, 5vh, 3.5rem) auto;
    padding-inline: 2rem;
  }

  .section-divider::before {
    content: "";
    display: block;
    height: 2px;
    background: var(--color-text);
    opacity: 0.18;
  }

  @media (width <= 700px) {
    .download-btn {
      display: flex;
      justify-content: center;
      width: 100%;
    }

    .section-divider {
      padding-inline: 1rem;
    }
  }
</style>
