---
import { projects } from "@cv";
import "@/styles/colors.css";
---

<ul>
  {
    projects.map(
      ({ name, startDate, description, highlights, keywords, url }) => {
        const startYear = new Date(startDate).getFullYear();

        return (
          <li>
            <article>
              <header>
                <div class="project-info">
                  <h3>
                    <a href={url} title={`View ${name}`} target="_blank">
                      {name}
                    </a>
                  </h3>
                  <p class="description">{description}</p>
                </div>
                <time class="date-range">{startYear}</time>
              </header>
              <footer>
                <ul class="highlights">
                  {highlights.map((highlight) => (
                    <li>{highlight}</li>
                  ))}
                </ul>
                {keywords && keywords.length > 0 && (
                  <div class="keywords">
                    {keywords.map((keyword) => (
                      <span class="keyword">{keyword}</span>
                    ))}
                  </div>
                )}
              </footer>
            </article>
          </li>
        );
      },
    )
  }
</ul>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin: 1rem 0 0 0;
    padding: 0;
    list-style: none;
  }

  li {
    padding-top: 1rem;
    border-top: 2px solid rgba(var(--color-accent-rgb), 0.5);
  }

  li:first-child {
    padding-top: 0;
    border-top: none;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .project-info {
    flex: 1;
    margin: 0;
  }

  article h3 {
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.2;
    margin: 0;
    padding: 0;
  }

  article a {
    color: var(--color-text);
    transition: color 0.2s ease;
  }

  article a:hover {
    color: var(--color-accent);
  }

  .description {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
    margin: 0.5rem 0 0 0;
    padding: 0;
    line-height: 1.5;
    opacity: 0.9;
  }

  .highlights li {
    position: relative;
    font-weight: 400;
    font-size: 0.85rem;
    line-height: 1.6;
    margin: 0.25rem 0;
    padding: 0 0 0 1.35rem;
    border: none;
    opacity: 0.85;
  }

  .highlights li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }

  footer {
    margin-top: 0.75rem;
  }

  .highlights {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin: 0 0 0.75rem 0;
  }

  .keywords {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .keyword {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.5rem;
    border: 3px solid var(--color-accent);
    color: var(--color-accent);
  }

  .date-range {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 900;
    white-space: nowrap;
    padding: 0.25rem 0.5rem;
    margin: 0;
    border: 2px solid var(--color-accent);
    line-height: 1.1;
  }

  @media (width <= 700px) {
    header {
      flex-direction: column;
      gap: 0.25rem;
    }

    .project-info {
      width: 100%;
    }

    article h3 {
      text-align: center !important;
    }

    .date-range {
      font-size: 0.75rem;
      display: inline-flex;
      width: 100%;
    }
  }
</style>
