---
import "@/styles/colors.css";

interface Props {
  title: string;
  description: string;
  image?: string;
  url?: string;
  techStack: string[];
  role: string;
  slug: string;
  index?: number;
}

const {
  title,
  description,
  image,
  url,
  techStack,
  role,
  slug,
  index = 0,
} = Astro.props;

const isVideo = image?.endsWith(".webm") || image?.endsWith(".mp4");
---

<article class="card has-texture-hover" style={`--i: ${index}`}>
  <a href={`/projects/${slug}`} class="card-link">
    {
      image ? (
        <div class="image-box">
          {isVideo ? (
            <video src={image} autoplay loop muted playsinline />
          ) : (
            <img src={image} alt={title} loading="lazy" />
          )}
          <span class="card-index">{String(index + 1).padStart(2, "0")}</span>
          <div class="image-accent" />
        </div>
      ) : (
        <div class="image-box placeholder-box" aria-hidden="true">
          <span class="card-index">{String(index + 1).padStart(2, "0")}</span>
        </div>
      )
    }
    <div class="content">
      <span class="role">{role}</span>
      <h3>{title}</h3>
      <div class="bar"></div>
      <p>{description}</p>
    </div>
  </a>
  <footer>
    <ul class="tags">
      {techStack.slice(0, 2).map((tech) => <li>{tech}</li>)}
      {
        techStack.length > 2 && (
          <li class="tag-more">+{techStack.length - 2}</li>
        )
      }
    </ul>
    <div class="links">
      {
        url && (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="external"
            aria-label={`Visit live site for ${title}`}
          >
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path
                d="M13.5 9.75V14.25C13.5 14.8467 13.2629 15.419 12.841 15.841C12.419 16.2629 11.8467 16.5 11.25 16.5H3.75C3.15326 16.5 2.58097 16.2629 2.15901 15.841C1.73705 15.419 1.5 14.8467 1.5 14.25V6.75C1.5 6.15326 1.73705 5.58097 2.15901 5.15901C2.58097 4.73705 3.15326 4.5 3.75 4.5H8.25M11.25 1.5H16.5M16.5 1.5V6.75M16.5 1.5L7.5 10.5"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </a>
        )
      }
    </div>
  </footer>
</article>

<style>
  .card {
    position: relative;
    background: var(--color-background);
    border: 3px solid var(--color-text);
    overflow: hidden;
    animation: slideUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) backwards;
    animation-delay: calc(var(--i) * 0.1s);
  }

  .card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--color-accent);
    transform: translateX(-101%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 0;
  }

  .card:hover::before,
  .card:focus-within::before {
    transform: translateX(0);
  }

  .card:hover,
  .card:focus-within {
    border-color: var(--color-accent);
  }

  .card:hover .content,
  .card:hover footer,
  .card:focus-within .content,
  .card:focus-within footer {
    color: var(--color-background);
  }

  .card:hover .role,
  .card:focus-within .role {
    color: var(--color-background);
    border-color: var(--color-background);
  }

  .card:hover .bar,
  .card:focus-within .bar {
    background: var(--color-background);
  }

  .card:hover .tags li,
  .card:focus-within .tags li {
    border-color: var(--color-background);
    color: var(--color-background);
  }

  .card:hover .external,
  .card:focus-within .external {
    color: var(--color-background);
    border-color: var(--color-background);
  }

  .card-link {
    display: block;
    color: inherit;
    position: relative;
    z-index: 1;
  }

  .image-box {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16/10;
  }

  .card-index {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2rem;
    height: 2rem;
    padding: 0 0.4rem;
    background: var(--color-background);
    border: 2px solid var(--color-accent);
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 900;
    line-height: 1;
  }

  .card:hover .card-index,
  .card:focus-within .card-index {
    background: var(--color-background);
    border-color: var(--color-background);
    color: var(--color-accent);
  }

  video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    filter: grayscale(20%);
  }

  .placeholder-box {
    background: linear-gradient(
        135deg,
        rgba(var(--color-accent-rgb), 0.16),
        transparent 55%
      ),
      repeating-linear-gradient(
        135deg,
        rgba(var(--color-text-rgb), 0.12) 0 2px,
        transparent 2px 16px
      ),
      rgba(var(--color-text-rgb), 0.04);
    border-bottom: 2px solid var(--color-text);
  }

  .placeholder-box::after {
    content: "Case study in progress";
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    padding: 0.35rem 0.55rem;
    border: 2px solid var(--color-accent);
    color: var(--color-accent);
    font-size: 0.72rem;
    font-weight: 800;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .card:hover .placeholder-box,
  .card:focus-within .placeholder-box {
    border-color: var(--color-background);
  }

  .card:hover .placeholder-box::after,
  .card:focus-within .placeholder-box::after {
    color: var(--color-background);
    border-color: var(--color-background);
  }

  img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    filter: grayscale(20%);
  }

  .card:hover img,
  .card:hover video,
  .card:focus-within img,
  .card:focus-within video {
    transform: scale(1.08);
    filter: grayscale(0%);
  }

  .image-accent {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 40%;
    background: linear-gradient(
      to top,
      var(--color-background) 0%,
      transparent 100%
    );
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .card:hover .image-accent,
  .card:focus-within .image-accent {
    opacity: 0;
  }

  .content {
    padding: 1.25rem;
    position: relative;
    z-index: 1;
    transition: color 0.3s ease;
  }

  .role {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    border: 2px solid var(--color-accent);
    padding: 0.25rem 0.5rem;
    margin-bottom: 0.75rem;
    transition: all 0.3s ease;
  }

  h3 {
    font-size: 1.5rem;
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1;
    margin: 0 0 0.75rem;
    padding: 0;
    letter-spacing: 0;
  }

  .bar {
    width: 60px;
    height: 4px;
    background: var(--color-accent);
    margin-bottom: 0.75rem;
    transition: background 0.3s ease;
  }

  p {
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
    padding: 0;
    opacity: 0.85;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    border-top: 2px solid var(--color-text);
    position: relative;
    z-index: 1;
    transition:
      color 0.3s ease,
      border-color 0.3s ease;
  }

  .card:hover footer,
  .card:focus-within footer {
    border-color: var(--color-background);
  }

  .tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tags li {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.4rem;
    border: 1px solid var(--color-text);
    transition: all 0.3s ease;
  }

  .tags .tag-more {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .links {
    display: flex;
    gap: 0.5rem;
  }

  .external {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 2px solid var(--color-text);
    color: var(--color-text);
    transition: all 0.3s ease;
  }

  .external:hover {
    background: var(--color-background);
    color: var(--color-accent);
    border-color: var(--color-background);
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (width <= 700px) {
    h3 {
      font-size: 1.25rem;
    }

    .content {
      padding: 1rem;
    }

    footer {
      padding: 0.75rem 1rem;
    }
  }
</style>
