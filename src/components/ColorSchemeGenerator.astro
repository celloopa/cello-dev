---
// ColorSchemeGenerator.astro
---

<div class="generator-wrapper">
  <div class="input">
    <label for="colorPicker" class="sr-only">Base color</label>
    <input type="color" id="colorPicker" aria-label="Base color" />
    <label for="scheme-selector" class="sr-only">Color scheme</label>
    <select id="scheme-selector">
      <option value="monochrome">Monochrome</option>
      <option value="monochrome-dark">Monochrome-dark</option>
      <option value="monochrome-light">Monochrome-light</option>
      <option value="analogic">Analogic</option>
      <option value="complement">Complement</option>
      <option value="analogic-complement">Analogic-complement</option>
      <option value="triad">Triad</option>
      <option value="quad">Quad</option>
    </select>
    <button id="submit">Generate</button>
  </div>
  <p id="color-status" class="status" aria-live="polite"></p>
  <div id="color-container"></div>
</div>

<style>
  .generator-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    row-gap: 2rem;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
  }

  .input {
    display: flex;
    justify-content: center;
    gap: 1rem;
    padding-block: 0.75rem;
    flex-wrap: wrap;
  }

  #color-container {
    display: flex;
    justify-content: center;
    width: 100%;
  }
  @media (max-width: 570px) {
    #color-container.many-colors {
      flex-wrap: wrap;
      justify-content: space-between;
    }
  }
  @media (max-width: 570px) {
    #color-container.many-colors .color-div {
      flex: 0 0 calc(33.333% - 0.5rem);
      max-width: calc(33.333% - 0.5rem);
    }
  }
  button,
  input,
  select {
    cursor: pointer;
    text-align: center;
    border-style: solid;
    border-radius: 0;
    border-color: var(--color-accent);
    background-color: var(--color-accent);
    color: var(--color-text);
    font-weight: 600;
    min-height: 44px;
    padding: 0.35rem 0.65rem;
  }

  input[type="color"] {
    width: 44px;
    padding: 0.2rem;
  }

  button:hover,
  input:hover,
  select:hover {
    background-color: transparent;
    border-color: var(--color-text);
  }

  :global(.color-div) {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  :global(.color-block) {
    cursor: pointer;
    aspect-ratio: 1/2.5;
    padding: 0;
    height: 8rem;
    margin-bottom: 2px;
    border-radius: 0;
    border-style: solid;
    border-color: var(--color-accent);
  }

  .status {
    min-height: 1.5rem;
    margin: -1rem 0 0;
    color: var(--color-accent);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  :global(.hex-text) {
    font-size: 0.75rem;
    cursor: pointer;
  }

  :global(.hex-text:hover) {
    color: var(--color-accent);
  }

  :global(.color-block:hover) {
    border-color: var(--color-text);
  }

  :global(.tooltip) {
    position: absolute;
    background: var(--color-accent);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    transform: translateY(-2.75rem);
  }
</style>

<script>
  interface ColorResponse {
    hex: {
      value: string;
      clean: string;
    };
    rgb: {
      value: string;
    };
    name: {
      value: string;
    };
  }

  interface SchemeResponse {
    mode: string;
    count: number;
    colors: ColorResponse[];
    seed: {
      hex: {
        value: string;
      };
    };
  }

  type SchemeType =
    | "monochrome"
    | "monochrome-dark"
    | "monochrome-light"
    | "analogic"
    | "complement"
    | "analogic-complement"
    | "triad"
    | "quad";

  async function getScheme(
    hexColor: string,
    scheme: SchemeType,
  ): Promise<SchemeResponse | undefined> {
    let count: number;
    switch (scheme) {
      case "monochrome":
      case "monochrome-dark":
      case "monochrome-light":
      case "analogic":
        count = 5;
        break;
      case "complement":
      case "quad":
        count = 4;
        break;
      case "triad":
        count = 3;
        break;
      case "analogic-complement":
        count = 6;
        break;
      default:
        count = 5;
    }
    try {
      const response = await fetch(
        `https://www.thecolorapi.com/scheme?hex=${hexColor.replace("#", "")}&mode=${scheme}&count=${count}`,
      );
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }
      const data: SchemeResponse = await response.json();
      return data;
    } catch {
      return undefined;
    }
  }

  function setStatus(message: string) {
    const status = document.getElementById("color-status");
    if (status) status.textContent = message;
  }

  async function handleSubmit() {
    const colorPicker = document.getElementById(
      "colorPicker",
    ) as HTMLInputElement | null;
    const schemeSelector = document.getElementById(
      "scheme-selector",
    ) as HTMLSelectElement | null;
    const container = document.getElementById("color-container");

    if (!colorPicker || !schemeSelector || !container) {
      setStatus("Generator controls are unavailable.");
      return;
    }

    const hex = colorPicker.value;
    const mode = schemeSelector.value as SchemeType;
    setStatus("Generating palette...");
    const result = await getScheme(hex, mode);

    if (!result) {
      setStatus("Could not generate a palette. Try again.");
      return;
    }

    container.innerHTML = "";
    if (mode === "analogic-complement") {
      container.classList.add("many-colors");
    } else {
      container.classList.remove("many-colors");
    }
    result.colors.forEach((color: ColorResponse) => {
      const wrapper = document.createElement("div");
      wrapper.className = "color-div";

      const colorDiv = document.createElement("div");
      colorDiv.className = "color-block";
      colorDiv.style.backgroundColor = color.hex.value;

      const hexText = document.createElement("p");
      hexText.className = "hex-text";
      hexText.textContent = color.hex.value;

      const copyHex = () => {
        navigator.clipboard
          .writeText(color.hex.value)
          .then(() => {
            const tooltip = document.createElement("span");
            tooltip.textContent = "Copied!";
            tooltip.className = "tooltip";
            wrapper.appendChild(tooltip);
            setTimeout(() => tooltip.remove(), 1000);
          })
          .catch(() => setStatus("Could not copy color."));
      };

      colorDiv.addEventListener("click", copyHex);
      hexText.addEventListener("click", copyHex);

      wrapper.appendChild(colorDiv);
      wrapper.appendChild(hexText);
      container.appendChild(wrapper);
    });
    setStatus(`${result.colors.length} colors generated.`);
  }

  function initColorGenerator() {
    const submitButton = document.getElementById("submit");
    if (submitButton) {
      submitButton.removeEventListener("click", handleSubmit);
      submitButton.addEventListener("click", handleSubmit);
    }
  }

  document.addEventListener("DOMContentLoaded", initColorGenerator);
  document.addEventListener("astro:after-swap", initColorGenerator);
</script>
